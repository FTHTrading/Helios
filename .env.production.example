# ═══════════════════════════════════════════════════════════════════════
# HELIOS OS — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env.production and fill ALL [REQUIRED] values before deploying.
# ═══════════════════════════════════════════════════════════════════════

# [REQUIRED] Environment mode
HELIOS_ENV=production

# [REQUIRED] Generate: python -c "import secrets; print(secrets.token_hex(32))"
HELIOS_SECRET_KEY=replace-with-strong-secret
HELIOS_DEBUG=false
HELIOS_HOST=0.0.0.0
HELIOS_PORT=5050

# [REQUIRED] Generate: python -c "import secrets; print(secrets.token_hex(24))"
HELIOS_API_KEY=

# [REQUIRED] PostgreSQL — SQLite NOT allowed in production
HELIOS_DATABASE_URL=postgresql://user:password@host:5432/helios

# [REQUIRED] Redis — rate limiting + background jobs
HELIOS_REDIS_URL=redis://redis:6379/0

# Build identity / route
HELIOS_BUILD_ID=
HELIOS_BUILD_WATERMARK=
HELIOS_LAUNCH_KEY=
HELIOS_DEPLOYMENT_ROUTE=full
HELIOS_BUILD_OWNER=FTHTrading
HELIOS_WATERMARK_MODE=hidden

# AI
HELIOS_AI_API_KEY=
HELIOS_AI_MODEL=gpt-4.1-mini

# Cloudflare
HELIOS_CF_TOKEN=
HELIOS_CF_ZONE_ID=

# XRPL — Primary Issuance Rail
HELIOS_XRPL_NETWORK=mainnet
HELIOS_XRPL_NODE=https://xrplcluster.com
HELIOS_XRPL_ENABLE_SUBMIT=true
HELIOS_XRPL_ISSUER_WALLET=
HELIOS_XRPL_ISSUER_SECRET=
HELIOS_XRPL_TREASURY_WALLET=
HELIOS_XRPL_TREASURY_SECRET=

# EVM / ERC-20 — Secondary Issuance Rail (optional)
HELIOS_EVM_RPC_URL=
HELIOS_EVM_CHAIN_ID=1
HELIOS_EVM_PRIVATE_KEY=
HELIOS_EVM_CONTRACT_ADDRESS=

# Stripe — Payment Processing
HELIOS_STRIPE_SECRET_KEY=
HELIOS_STRIPE_PUBLISHABLE_KEY=
HELIOS_STRIPE_WEBHOOK_SECRET=
HELIOS_PAYMENTS_SUCCESS_URL=https://heliosdigital.xyz/activate
HELIOS_PAYMENTS_CANCEL_URL=https://heliosdigital.xyz/join

# Xaman — Wallet Signing
HELIOS_XAMAN_API_KEY=
HELIOS_XAMAN_API_SECRET=

# IPFS / Pinata — NFT Metadata
HELIOS_IPFS_GATEWAY=https://ipfs.io/ipfs/
HELIOS_PINATA_JWT=
HELIOS_PINATA_API_KEY=
HELIOS_PINATA_SECRET_API_KEY=

# Telnyx — SMS Verification
HELIOS_TELNYX_API_KEY=
HELIOS_TELNYX_FROM_NUMBER=

# ElevenLabs — Voice AI
HELIOS_ELEVENLABS_API_KEY=
HELIOS_ELEVENLABS_VOICE_ID=29vD33N1CtxCmqQRPOHJ
HELIOS_GUIDE_VOICE_ID=2EiwWnXFnvU5JabPnv8n

# Monitoring
HELIOS_SENTRY_DSN=
HELIOS_REDIS_URL=redis://redis:6379/0
HELIOS_RATE_LIMIT_DEFAULT=200 per hour;50 per minute

# Gold Pricing (fallback if no live feed)
HELIOS_GOLD_SPOT_PRICE_USD=2350

# Docker PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_SECURE

