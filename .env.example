# Helios OS  Environment Variables
HELIOS_SECRET_KEY=change-me-in-production
HELIOS_DEBUG=true
HELIOS_PORT=5050
HELIOS_DATABASE_URL=sqlite:///data/helios.db
HELIOS_BUILD_ID=
HELIOS_BUILD_WATERMARK=
HELIOS_LAUNCH_KEY=
HELIOS_DEPLOYMENT_ROUTE=simplified
HELIOS_BUILD_OWNER=FTHTrading
HELIOS_WATERMARK_MODE=hidden

# ElevenLabs  Voice AI (Ask Helios speaks)
HELIOS_ELEVENLABS_API_KEY=
HELIOS_ELEVENLABS_VOICE_ID=

# Cloudflare  DNS / CDN / SSL
HELIOS_CF_TOKEN=
HELIOS_CF_ZONE_ID=

# Telnyx  SMS / Phone Verification
HELIOS_TELNYX_API_KEY=
HELIOS_TELNYX_FROM_NUMBER=

# AI (OpenAI for Ask Helios fallback)
HELIOS_AI_API_KEY=
HELIOS_AI_MODEL=gpt-4.1-mini

# XRPL  Production Rails
HELIOS_XRPL_NETWORK=testnet
HELIOS_XRPL_NODE=https://s.altnet.rippletest.net:51234
HELIOS_XRPL_ENABLE_SUBMIT=false
HELIOS_XRPL_ISSUER_WALLET=
HELIOS_XRPL_ISSUER_SECRET=
HELIOS_XRPL_TREASURY_WALLET=
HELIOS_XRPL_TREASURY_SECRET=

# IPFS / Pinata  Evidence Bundles
HELIOS_IPFS_GATEWAY=https://ipfs.io/ipfs/
HELIOS_PINATA_JWT=
HELIOS_PINATA_API_KEY=
HELIOS_PINATA_SECRET_API_KEY=

# Stripe  Funding Engine
HELIOS_STRIPE_SECRET_KEY=
HELIOS_STRIPE_PUBLISHABLE_KEY=
HELIOS_STRIPE_WEBHOOK_SECRET=
HELIOS_PAYMENTS_SUCCESS_URL=https://heliosdigital.xyz/activate
HELIOS_PAYMENTS_CANCEL_URL=https://heliosdigital.xyz/join

# Xaman / XUMM  Wallet Signing
HELIOS_XAMAN_API_KEY=
HELIOS_XAMAN_API_SECRET=

# Ops
HELIOS_REDIS_URL=
HELIOS_SENTRY_DSN=
HELIOS_RATE_LIMIT_DEFAULT=200 per hour;50 per minute
